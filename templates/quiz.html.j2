<!doctype html>
<html lang="de">
  <head>
    <!-- Zeichencodierung und responsive Darstellung -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <!-- Titel der Seite im Browser -->
    <title>Abschluss-Quiz</title>

    <!-- CSS -->
    <link rel="stylesheet" href="style/style.css" />

    <!-- Font Awesome für Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>

  <body>
    <!-- Oberer Navigationsbereich -->
    <header class="topbar">
      <nav class="topbar-left" aria-label="Hauptnavigation">
        <!-- Link zurück zur Übersichtsseite -->
        <a class="tb-link" href="index.html">
          <i class="fa-solid fa-list"></i> Index
        </a>

        <!-- Link zum Glossar -->
        <a class="tb-link" href="glossar.html">
          <i class="fa-solid fa-book"></i> Glossar
        </a>
      </nav>

      <!-- Mittlerer Bereich mit aktueller Seitenbezeichnung -->
      <div class="slide-nav" aria-label="Seite">
        <span class="nav-meta">
          <i class="fa-solid fa-circle-question"></i> Quiz
        </span>
      </div>

      <!-- Button zum Wechseln des Themes -->
      <div class="topbar-right">
        <button id="theme-toggle" class="tb-btn" aria-label="Theme wechseln">
          <i class="fa-solid fa-moon"></i>
        </button>
      </div>
    </header>

    <!-- Hauptbereich der Quiz-Seite -->
    <div class="wrap">
      <h1>Abschluss-Quiz</h1>
      <p class="muted">
        Pro Folie ein Lückentext. Tipp die fehlende Stelle ein.
      </p>

      <!-- Quizfragen per JavaScript eingefügen -->
      <div id="quiz-root"></div>
    </div>

    <!-- JSON-Daten für das Quiz werden unsichtbar im HTML eingebettet -->
    <script id="quiz-data" type="application/json">
      {{ quiz_data_inline | safe }}
    </script>

    <script>
      (function () {
        <!-- Gesamter Quiz-Code -->

        (function () {
          // Theme-Umschaltung zwischen Hell- und Dunkelmodus
          const rootEl = document.documentElement;
          const toggle = document.getElementById("theme-toggle");
          if (!toggle) return;

          const saved = localStorage.getItem("theme");
          if (saved) {
            rootEl.setAttribute("data-theme", saved);
          } else if (
            window.matchMedia &&
            window.matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            rootEl.setAttribute("data-theme", "dark");
          }

          function updateIcon() {
            // Passt das Icon an das aktuelle Theme an
            const current = rootEl.getAttribute("data-theme");
            toggle.innerHTML =
              current === "dark"
                ? '<i class="fa-solid fa-sun"></i>'
                : '<i class="fa-solid fa-moon"></i>';
          }

          updateIcon();

          toggle.addEventListener("click", () => {
            // Wechselt das Theme und speichert die Auswahl
            const current = rootEl.getAttribute("data-theme");
            const next = current === "dark" ? "light" : "dark";
            rootEl.setAttribute("data-theme", next);
            localStorage.setItem("theme", next);
            updateIcon();
          });
        })();

        // Container für die Quizkarten
        const root = document.getElementById("quiz-root");

        // Eingebettete JSON-Daten aus dem Script-Tag lesen
        const data = JSON.parse(
          document.getElementById("quiz-data").textContent,
        );

        // Falls keine Fragen vorhanden sind, Hinweis anzeigen
        if (!data || !data.length) {
          root.innerHTML = "<p>Kein Quiz generiert (0 Fragen).</p>";
          return;
        }

        function norm(s) {
          return (s || "").trim().toLowerCase();
        }

        // Für jede Frage eine eigene Quizkarte erzeugen
        data.forEach((q, i) => {
          const card = document.createElement("div");
          card.className = "quiz-card";

          // Überschrift der Frage
          const h = document.createElement("h3");
          h.textContent = "Frage " + (i + 1);
          card.appendChild(h);

          // Fragetext
          const p = document.createElement("div");
          p.className = "quiz-q";
          p.textContent = q.question;
          card.appendChild(p);

          // Eingabebereich mit Buttons
          const row = document.createElement("div");
          row.className = "quiz-row";

          const inp = document.createElement("input");
          inp.type = "text";
          inp.placeholder = "Fehlendes Wort eingeben…";
          row.appendChild(inp);

          const btn = document.createElement("button");
          btn.type = "button";
          btn.textContent = "Prüfen";
          row.appendChild(btn);

          const reveal = document.createElement("button");
          reveal.type = "button";
          reveal.textContent = "Lösung anzeigen";
          row.appendChild(reveal);

          card.appendChild(row);

          // Bereich für Rückmeldung, ob die Antwort richtig oder falsch ist
          const result = document.createElement("div");
          result.className = "quiz-result";
          card.appendChild(result);

          // Link zur zugehörigen Folie
          const link = document.createElement("div");
          link.className = "quiz-link";
          link.innerHTML = q.slide
            ? `<i class="fa-solid fa-magnifying-glass"></i> <a href="${q.slide}">Zur Folie öffnen</a>`
            : "";
          card.appendChild(link);

          function check() {
            // Prüft die Eingabe des Nutzers mit der richtigen Antwort
            const ok = norm(inp.value) === norm(q.answer);
            result.innerHTML = ok
              ? '<i class="fa-solid fa-circle-check"></i> Richtig!'
              : '<i class="fa-solid fa-circle-xmark"></i> Falsch. (Tipp: Groß/Kleinschreibung egal)';
          }

          // Klick auf "Prüfen"
          btn.onclick = check;

          // Auch mit Enter-Taste prüfen
          inp.addEventListener("keydown", (e) => {
            if (e.key === "Enter") check();
          });

          // Zeigt die Lösung direkt an
          reveal.onclick = () => {
            result.innerHTML =
              '<i class="fa-solid fa-circle-check"></i> Lösung: ' + q.answer;
          };

          // Karte an den Hauptbereich anhängen
          root.appendChild(card);
        });
      })();
    </script>
  </body>
</html>
