  "semantik": {
    "segmentierung": {
      "abschnitte": [
        "Finanzwesen & Betrugserkennung\nFinanzwesen & Betrugserkennung\nIm Finanzsektor wird Big Data eingesetzt, um Risiken zu minimieren und Betrug frühzeitig zu erkennen. Echtzeit-\nAnalysen sind hier besonders entscheidend.\n• Transaktionen werden kontinuierlich auf Anomalien überprüft.\n• Kreditrisikobewertungen integrieren vielfältige Datenquellen.\n• Hochfrequenzhandel basiert auf algorithmischer Marktanalyse.\n• Betrugsprävention erhöht Sicherheit und Vertrauen im Finanzsystem."
      ],
      "saetze": [
        "Finanzwesen & Betrugserkennung",
